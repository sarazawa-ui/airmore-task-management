rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // ドメイン制限（①）：許可ドメインのアカウントのみ読み書き可
    //   - 固定5ドメインはルールに直書き（ハードバックストップ）
    //   - 追加ドメインは appConfig/authDomains.domains（admin が UI で管理）
    // =========================================================
    function _fixedDomainOk(email) {
      return email.lower().matches('.*@(nimomakezu\\.com|leaklab-japan\\.com|n-mobily\\.com|n-airmore\\.com|dustlabo\\.com)');
    }
    function _extraDomainOk(email) {
      return exists(/databases/$(database)/documents/appConfig/authDomains)
        && email.lower().split('@')[1] in get(/databases/$(database)/documents/appConfig/authDomains).data.domains;
    }
    function _domainOk() {
      return request.auth != null
        && (_fixedDomainOk(request.auth.token.email) || _extraDomainOk(request.auth.token.email));
    }

    // =========================================================
    // アプリ管理者（admin）：ブートストラップ＋appConfig/admins.emails
    // =========================================================
    function _isAppAdmin(email) {
      return email in ['sarazawa@n-airmore.com', 'sarazawa@leaklab-japan.com']
        || (exists(/databases/$(database)/documents/appConfig/admins)
            && email in get(/databases/$(database)/documents/appConfig/admins).data.emails);
    }

    // === アプリ設定（許可ドメイン・admin 一覧） ===
    //   読み取り：ログイン時のドメイン判定に必要なため認証済みなら可（中身はドメイン/メール一覧のみ）
    //   書き込み：admin のみ
    match /appConfig/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && _isAppAdmin(request.auth.token.email);
    }

    // === Workspace 本体 ===
    // 許可ドメインのユーザーのみ読み書き可（メンバーシップはクライアント側で管理）
    match /workspaces/{wsId} {
      allow read, write: if _domainOk();

      match /tasks/{doc=**}          { allow read, write: if _domainOk(); }
      match /goals/{doc=**}          { allow read, write: if _domainOk(); }
      match /weeklyReports/{doc=**}  { allow read, write: if _domainOk(); }
      match /history/{doc=**}        { allow read, write: if _domainOk(); }
      match /meetings/{doc=**}       { allow read, write: if _domainOk(); }
      match /shared/{doc=**}         { allow read, write: if _domainOk(); }
      match /pushTokens/{doc=**}     { allow read, write: if _domainOk(); }

      // === Budget subcollection（旧パス互換） ===
      match /budget/{doc=**} {
        allow read: if _domainOk()
          && _budgetRole(wsId, request.auth.token.email) in ['admin', 'editor', 'viewer'];
        allow write: if _domainOk()
          && _budgetRole(wsId, request.auth.token.email) in ['admin', 'editor'];
      }
    }

    // === Global Budget（WS非依存・全ユーザー共通） ===
    // 許可ドメインのユーザーのみ。ロール細分はアプリ層（AuthGate）で制御
    match /globalBudget/roles {
      allow read: if _domainOk();
      allow write: if _domainOk() && _gbAdminOk(request.auth.token.email);
    }
    match /globalBudget/userCompanies {
      allow read: if _domainOk();
      allow write: if _domainOk();
    }
    match /globalBudget/data {
      allow read: if _domainOk();
      allow write: if _domainOk();
    }
    match /globalBudget/{doc} {
      allow read: if _domainOk();
      allow write: if _domainOk();
    }

    // === Budget Access Requests ===
    match /budgetAccessRequests/{email} {
      allow read, write: if _domainOk()
        && request.auth.token.email == email;
      allow read, write: if _domainOk()
        && _gbAdminOk(request.auth.token.email);
    }

    // === sentReminders（Cloud Functions のみ）===
    match /sentReminders/{id} {
      allow read, write: if false;
    }
  }

  // ヘルパ関数：workspaces/{wsId}.budgetRoles[email] を返す（旧パス互換）
  function _budgetRole(wsId, email) {
    return get(/databases/$(database)/documents/workspaces/$(wsId))
      .data.get('budgetRoles', {}).get(email, null);
  }

  // === Global Budget ヘルパ ===
  function _isBootstrapAdmin(email) {
    return email == 'sarazawa@n-airmore.com';
  }
  function _gbRole(email) {
    return exists(/databases/$(database)/documents/globalBudget/roles)
      ? get(/databases/$(database)/documents/globalBudget/roles).data.get('roles', {}).get(email, null)
      : null;
  }
  function _gbReadOk(email) {
    return _isBootstrapAdmin(email) || _gbRole(email) in ['admin', 'editor', 'viewer'];
  }
  function _gbWriteOk(email) {
    return _isBootstrapAdmin(email) || _gbRole(email) in ['admin', 'editor'];
  }
  function _gbAdminOk(email) {
    return _isBootstrapAdmin(email) || _gbRole(email) == 'admin';
  }
}
